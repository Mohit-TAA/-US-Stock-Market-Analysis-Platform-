# StockAI Pro - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME="StockAI Pro"
APP_URL=http://localhost:8501
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production

# ============================================
# DATABASE CONFIGURATION
# ============================================
# For local development (SQLite)
DATABASE_URL=data/pro_us_market.db

# For production (PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/stockai

# For production (MySQL)
# DATABASE_URL=mysql://user:password@localhost:3306/stockai

# ============================================
# AI SERVICES
# ============================================
# OpenAI API (Primary AI Provider)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic API (Alternative AI Provider)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# PAYMENT PROCESSING (Stripe)
# ============================================
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Product IDs (Create in Stripe Dashboard)
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ============================================
# EMAIL SERVICE (SendGrid)
# ============================================
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME="StockAI Pro"

# ============================================
# MARKET DATA APIs
# ============================================
# News API (for sentiment analysis)
# Get your API key from: https://newsapi.org/register
NEWS_API_KEY=...

# Finnhub API (additional market data)
# Get your API key from: https://finnhub.io/register
FINNHUB_API_KEY=...

# Alpha Vantage (optional)
# Get your API key from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=...

# ============================================
# REDIS (Optional - for session management)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=INFO
SENTRY_DSN=

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_AI_FEATURES=true
ENABLE_PAPER_TRADING=true
ENABLE_API_ACCESS=true
ENABLE_SOCIAL_LOGIN=false

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_FREE=10
RATE_LIMIT_BASIC=100
RATE_LIMIT_PRO=1000
RATE_LIMIT_ENTERPRISE=-1

# ============================================
# SOCIAL AUTH (Optional)
# ============================================
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...

# ============================================
# ANALYTICS (Optional)
# ============================================
GOOGLE_ANALYTICS_ID=UA-...
MIXPANEL_TOKEN=...

# ============================================
# CDN & STORAGE (Optional)
# ============================================
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=stockai-reports
AWS_REGION=us-east-1

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
DEBUG=false
TESTING=false
MOCK_PAYMENTS=false
